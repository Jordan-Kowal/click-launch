    "lucide-solid": "1.14.0",
    "solid-js": "1.9.12",
    "solid-toast": "0.5.0",
    "uplot": "1.6.32"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/js-yaml": "4.0.9",
    "daisyui": "5.5.19",
    "postcss": "8.5.13",
    "rimraf": "6.1.3",
    "solid-devtools": "0.34.5",
    "tailwindcss": "4.2.4",
