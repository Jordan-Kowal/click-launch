  ],
  "scripts": {
    "biome:check": "biome check ./src",
    "biome:check:fix": "biome check ./src --write --unsafe",
    "tsc": "tsc",
    "reinstall": "rimraf bun.lock node_modules/ && bun install"
  },
  "dependencies": {
